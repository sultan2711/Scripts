local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")
local VIM = game:GetService("VirtualInputManager")
local LP = Players.LocalPlayer

local ParticlesFolder = workspace:WaitForChild("Particles", 10)

local IsRunning = true
local AFK_POS = Vector3.new(287, -40, -16)
local Blacklist = {}
local PermanentBlacklist = {} 

-- Имя по умолчанию (на случай, если папка вообще пуста)
local targetName = "Cash"

-- СТАБИЛЬНЫЙ ПОИСК ИМЕНИ ОБРАЗЦА
if ParticlesFolder then
    local function findSampleName()
        for _, child in pairs(ParticlesFolder:GetChildren()) do
            -- Ищем любой BasePart, имя которого содержит "Cash" (или просто любой парт, если имя другое)
            if child:IsA("BasePart") and (string.find(child.Name, "Cash") or child:FindFirstChildOfClass("TouchInterest")) then
                return child.Name
            end
        end
        return nil
    end

    local sample = findSampleName()
    if sample then
        targetName = sample
        print("[MEGA FARM] Имя купюр автоматически определено по первому образцу:", targetName)
    else
        -- Если при старте папка пуста, ждем появления первого подходящего объекта
        task.spawn(function()
            print("[MEGA FARM] Папка пуста. Ожидаю появление первого образца для клонирования имени...")
            local connection
            connection = ParticlesFolder.ChildAdded:Connect(function(child)
                if child:IsA("BasePart") and child:FindFirstChildOfClass("TouchInterest") then
                    targetName = child.Name
                    print("[MEGA FARM] Имя успешно перехвачено при спавне:", targetName)
                    connection:Disconnect() -- Отключаем слежку, имя уже получено
                end
            end)
            
            -- Таймаут на случай, если вообще ничего не спавнится (чтобы не висел бесконечно)
            task.delay(15, function()
                if connection then connection:Disconnect() end
            end)
        end)
    end
end

if CoreGui:FindFirstChild("MegaFarmGui") then CoreGui.MegaFarmGui:Destroy() end
local ScreenGui = Instance.new("ScreenGui", CoreGui)
ScreenGui.Name = "MegaFarmGui"

local Frame = Instance.new("Frame", ScreenGui)
