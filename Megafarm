local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")
local VIM = game:GetService("VirtualInputManager")
local LP = Players.LocalPlayer

local ParticlesFolder = workspace:WaitForChild("Particles", 10)

local IsRunning = true
local AFK_POS = Vector3.new(287, -40, -16)
local Blacklist = {}
local PermanentBlacklist = {} 

if CoreGui:FindFirstChild("MegaFarmGui") then CoreGui.MegaFarmGui:Destroy() end
local ScreenGui = Instance.new("ScreenGui", CoreGui)
ScreenGui.Name = "MegaFarmGui"

local Frame = Instance.new("Frame", ScreenGui)
Frame.Size = UDim2.new(0, 160, 0, 40)
Frame.Position = UDim2.new(0.5, -80, 0, 20)
Frame.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
Frame.BorderSizePixel = 0

local Title = Instance.new("TextLabel", Frame)
Title.Size = UDim2.new(0.6, 0, 1, 0)
Title.Text = "MEGA FARM"
Title.TextColor3 = Color3.new(1, 1, 1)
Title.BackgroundTransparency = 1
Title.Font = Enum.Font.SourceSansBold
Title.TextSize = 14

local ClearBtn = Instance.new("TextButton", Frame)
ClearBtn.Size = UDim2.new(0.2, 0, 1, 0)
ClearBtn.Position = UDim2.new(0.6, 0, 0, 0)
ClearBtn.BackgroundColor3 = Color3.fromRGB(200, 120, 0)
ClearBtn.Text = "C"
ClearBtn.TextColor3 = Color3.new(1, 1, 1)
ClearBtn.Font = Enum.Font.SourceSansBold

local CloseBtn = Instance.new("TextButton", Frame)
CloseBtn.Size = UDim2.new(0.2, 0, 1, 0)
CloseBtn.Position = UDim2.new(0.8, 0, 0, 0)
CloseBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
CloseBtn.Text = "X"
CloseBtn.TextColor3 = Color3.new(1, 1, 1)
CloseBtn.Font = Enum.Font.SourceSansBold

local function getRoot()
    return LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid()
    return LP.Character and LP.Character:FindFirstChild("Humanoid")
end

local function stopFarming()
    IsRunning = false
    ScreenGui:Destroy()
end

local function clearBlacklists()
    table.clear(Blacklist)
    table.clear(PermanentBlacklist)
end

CloseBtn.MouseButton1Click:Connect(stopFarming)
ClearBtn.MouseButton1Click:Connect(clearBlacklists)

local function isValidCashPart(part)
    if not part or not part:IsA("BasePart") or part.Name ~= "Cash" or not part.Parent then
        return false
    end
    
    for _, child in pairs(part:GetChildren()) do
        if child.ClassName == "TouchTransmitter" or child.Name == "TouchInterest" then
            return true
        end
    end
    
    return false
end

local function getValidCash()
    local validItems = {}
    if not ParticlesFolder then return validItems end
    
    for _, v in pairs(ParticlesFolder:GetChildren()) do
        if not Blacklist[v] and not PermanentBlacklist[v] then 
            if isValidCashPart(v) then
                table.insert(validItems, v) 
            end
        end
    end
    return validItems
end

local function onCharacterAdded(char)
    if not IsRunning then return end
    local root = char:WaitForChild("HumanoidRootPart", 5)
    if root then
        local cashItems = getValidCash()
        if #cashItems == 0 then
            root.Velocity = Vector3.new(0, 0, 0)
            root.CFrame = CFrame.new(AFK_POS)
        end
    end
end

if LP.Character then task.spawn(onCharacterAdded, LP.Character) end
LP.CharacterAdded:Connect(onCharacterAdded)

task.spawn(function()
    while IsRunning do
        local hum = getHumanoid()
        if hum and hum.Health > 0 then
            VIM:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
            task.wait(0.05)
            VIM:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
        end
        task.wait(1)
    end
end)

local function collect(item)
    if not IsRunning or Blacklist[item] or PermanentBlacklist[item] then return end
    if not isValidCashPart(item) then return end

    local root = getRoot()
    local hum = getHumanoid()
    
    while (not root or not hum) and IsRunning do
        task.wait(0.1)
        root = getRoot()
        hum = getHumanoid()
    end
    
    if not root or not item.Parent then return end

    local counter = 0
    local startTime = tick()

    repeat
        if not IsRunning then break end
        
        if hum and hum.Health <= 0 then
            if item.Position.Y >= -19.5 then
                PermanentBlacklist[item] = true 
            end
            break
        end

        if tick() - startTime > 3 then
            if item.Position.Y >= -19.5 then
                Blacklist[item] = true
                task.delay(10, function()
                    Blacklist[item] = nil
                end)
            end
            break
        end

        root = getRoot()
        hum = getHumanoid()

        if root and hum and item.Parent and isValidCashPart(item) then
            local offset = math.sin(counter) * 5
            local rotX = math.cos(counter) * 180
            local rotY = counter * 150
            local rotZ = math.sin(counter) * 180
            
            root.CFrame = item.CFrame * CFrame.new(offset, 0, 0) * CFrame.Angles(math.rad(rotX), math.rad(rotY), math.rad(rotZ))
            counter = counter + 0.3
        end
        task.wait()
    until not item or not item.Parent or not isValidCashPart(item) or not item:IsDescendantOf(workspace) or not IsRunning or Blacklist[item] or PermanentBlacklist[item]
end

task.spawn(function()
    while IsRunning do
        local root = getRoot()
        local hum = getHumanoid()
        
        if root and hum and hum.Health > 0 then
            local cashItems = getValidCash()

            if #cashItems > 0 then
                for _, item in pairs(cashItems) do
                    if not IsRunning or Blacklist[item] or PermanentBlacklist[item] then break end
                    collect(item)
                end
            end
        end
        task.wait(0.2)
    end
end)

RunService.Heartbeat:Connect(function()
    if not IsRunning then return end
    
    local root = getRoot()
    local hum = getHumanoid()
    
    if root and hum and hum.Health > 0 then
        local cashItems = getValidCash()

        if #cashItems == 0 then
            root.Velocity = Vector3.new(0, 0, 0)
            root.RotVelocity = Vector3.new(0, 0, 0)
            root.CFrame = CFrame.new(AFK_POS)
        end
    end
end)

if ParticlesFolder then
    ParticlesFolder.ChildAdded:Connect(function(child)
        if IsRunning then
            task.wait(0.05)
            if isValidCashPart(child) then
                collect(child)
            end
        end
    end)
end
