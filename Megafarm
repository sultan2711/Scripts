CloseBtn.Text = "X"
CloseBtn.TextColor3 = Color3.new(1, 1, 1)
CloseBtn.Font = Enum.Font.SourceSansBold

print("[MEGA FARM] Стабильный скрипт запущен. Целевое имя:", targetName)

local function getRoot()
    return LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid()
    return LP.Character and LP.Character:FindFirstChild("Humanoid")
end

local function stopFarming()
    IsRunning = false
    print("[MEGA FARM] Фарм остановлен.")
    ScreenGui:Destroy()
end

CloseBtn.MouseButton1Click:Connect(stopFarming)

-- Проверка на реальность (имя совпадает с динамическим образцом + есть TouchInterest)
local function isRealCash(part)
    if not part or not part:IsA("BasePart") or not part.Parent then
        return false
    end
    return part.Name == targetName and part:FindFirstChildOfClass("TouchInterest") ~= nil
end

local function getValidCash()
    local validItems = {}
    if not ParticlesFolder then return validItems end
    
    for _, v in pairs(ParticlesFolder:GetChildren()) do
        if not Blacklist[v] and not PermanentBlacklist[v] then 
            if isRealCash(v) then
                table.insert(validItems, v) 
            end
        end
    end
    return validItems
end

local function onCharacterAdded(char)
    if not IsRunning then return end
    local root = char:WaitForChild("HumanoidRootPart", 5)
    if root then
        local cashItems = getValidCash()
        if #cashItems == 0 then
            root.Velocity = Vector3.new(0, 0, 0)
            root.CFrame = CFrame.new(AFK_POS)
        end
    end
end

if LP.Character then task.spawn(onCharacterAdded, LP.Character) end
LP.CharacterAdded:Connect(onCharacterAdded)

-- Защита от AFK-кика
task.spawn(function()
    while IsRunning do
        local hum = getHumanoid()
        if hum and hum.Health > 0 then
            VIM:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
            task.wait(0.05)
            VIM:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
        end
        task.wait(1)
    end
end)

local function collect(item)
    if not IsRunning or Blacklist[item] or PermanentBlacklist[item] or not isRealCash(item) then return end

    local root = getRoot()
    local hum = getHumanoid()
    
    while (not root or not hum) and IsRunning do
        task.wait(0.1)
        root = getRoot()
        hum = getHumanoid()
    end
    
    if not root or not item.Parent then return end

    print("[MEGA FARM] Сбор цели:", item:GetDebugId(4))
    local counter = 0
    local startTime = tick()

    repeat
        if not IsRunning then break end
        
        if hum and hum.Health <= 0 then
            warn("[MEGA FARM] Персонаж погиб. Монета в блеклисте:", item:GetDebugId(4))
            PermanentBlacklist[item] = true 
            break
        end

        if tick() - startTime > 3 then
            warn("[MEGA FARM] Зависание сбора. Пропуск на 10 сек:", item:GetDebugId(4))
            Blacklist[item] = true
            task.delay(10, function()
                Blacklist[item] = nil
            end)
            break
        end

        root = getRoot()
        hum = getHumanoid()

        if root and hum and item.Parent and isRealCash(item) then
            local offset = math.sin(counter) * 5
            local rotX = math.cos(counter) * 180
            local rotY = counter * 150
            local rotZ = math.sin(counter) * 180
            
            root.CFrame = item.CFrame * CFrame.new(offset, 0, 0) * CFrame.Angles(math.rad(rotX), math.rad(rotY), math.rad(rotZ))
            counter = counter + 0.3
        end
        task.wait()
    until not item or not item.Parent or not item:IsDescendantOf(workspace) or not IsRunning or Blacklist[item] or PermanentBlacklist[item] or not isRealCash(item)
end

-- Основной цикл сканирования
task.spawn(function()
    local lastCount = -1
    while IsRunning do
        local root = getRoot()
        local hum = getHumanoid()
        
        if root and hum and hum.Health > 0 then
            local cashItems = getValidCash()

            if #cashItems > 0 then
                if #cashItems ~= lastCount then
                    print("[MEGA FARM] Найдено реальных целей на сбор:", #cashItems)
                    lastCount = #cashItems
                end
                
                for _, item in pairs(cashItems) do
                    if not IsRunning or Blacklist[item] or PermanentBlacklist[item] then break end
                    collect(item)
                end
            else
                lastCount = 0
            end
        end
        task.wait(0.2)
    end
end)

-- Удержание AFK
local isAlreadyAFK = false
RunService.Heartbeat:Connect(function()
    if not IsRunning then return end
    
    local root = getRoot()
    local hum = getHumanoid()
    
    if root and hum and hum.Health > 0 then
        local cashItems = getValidCash()

        if #cashItems == 0 then
            if not isAlreadyAFK then
                print("[MEGA FARM] Целей нет. Ожидание на AFK позиции.")
                isAlreadyAFK = true
            end
            root.Velocity = Vector3.new(0, 0, 0)
            root.RotVelocity = Vector3.new(0, 0, 0)
            root.CFrame = CFrame.new(AFK_POS)
        else
            isAlreadyAFK = false
        end
    end
end)

-- Отслеживание спавна новых
if ParticlesFolder then
    ParticlesFolder.ChildAdded:Connect(function(child)
        if IsRunning then
            task.wait(0.05)
            if isRealCash(child) then
                print("[MEGA FARM] Спавн новой цели:", child:GetDebugId(4))
                collect(child)
            end
        end
    end)
end
