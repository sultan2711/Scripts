local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")
local LP = Players.LocalPlayer
local ParticlesFolder = workspace:WaitForChild("Particles")

local IsRunning = true
local AFK_POS = Vector3.new(287, -40, -16)
local Blacklist = {}
local PermanentBlacklist = {} 

if CoreGui:FindFirstChild("MegaFarmGui") then CoreGui.MegaFarmGui:Destroy() end
local ScreenGui = Instance.new("ScreenGui", CoreGui)
ScreenGui.Name = "MegaFarmGui"

local Frame = Instance.new("Frame", ScreenGui)
Frame.Size = UDim2.new(0, 130, 0, 40)
Frame.Position = UDim2.new(0.5, -65, 0, 20)
Frame.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
Frame.BorderSizePixel = 0

local Title = Instance.new("TextLabel", Frame)
Title.Size = UDim2.new(0.75, 0, 1, 0)
Title.Text = "MEGA FARM"
Title.TextColor3 = Color3.new(1, 1, 1)
Title.BackgroundTransparency = 1
Title.Font = Enum.Font.SourceSansBold
Title.TextSize = 14

local CloseBtn = Instance.new("TextButton", Frame)
CloseBtn.Size = UDim2.new(0.25, 0, 1, 0)
CloseBtn.Position = UDim2.new(0.75, 0, 0, 0)
CloseBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
CloseBtn.Text = "X"
CloseBtn.TextColor3 = Color3.new(1, 1, 1)
CloseBtn.Font = Enum.Font.SourceSansBold

print("[MEGA FARM] Скрипт успешно запущен. AFK Позиция:", tostring(AFK_POS))

local function getRoot()
    return LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid()
    return LP.Character and LP.Character:FindFirstChild("Humanoid")
end

local function stopFarming()
    IsRunning = false
    print("[MEGA FARM] Фарм остановлен пользователем.")
    ScreenGui:Destroy()
end

CloseBtn.MouseButton1Click:Connect(stopFarming)

-- Функция получения только валидных, существующих купюр
local function getValidCash()
    local validItems = {}
    for _, v in pairs(ParticlesFolder:GetChildren()) do
        if v.Name == "Cash" and v:IsA("BasePart") and v.Parent and not Blacklist[v] and not PermanentBlacklist[v] then 
            table.insert(validItems, v) 
        end
    end
    return validItems
end

local function onCharacterAdded(char)
    if not IsRunning then return end
    local root = char:WaitForChild("HumanoidRootPart", 5)
    if root then
        local cashItems = getValidCash()
        if #cashItems == 0 then
            print("[MEGA FARM] Монет нет. Мгновенный перенос нового персонажа на AFK позицию.")
            root.Velocity = Vector3.new(0, 0, 0)
            root.CFrame = CFrame.new(AFK_POS)
        end
    end
end

if LP.Character then task.spawn(onCharacterAdded, LP.Character) end
LP.CharacterAdded:Connect(onCharacterAdded)

local function collect(item)
    if not IsRunning or Blacklist[item] or PermanentBlacklist[item] then return end

    local root = getRoot()
    local hum = getHumanoid()
    
    while (not root or not hum) and IsRunning do
        task.wait(0.1)
        root = getRoot()
        hum = getHumanoid()
    end
    
    if not root or not item:IsA("BasePart") or not item.Parent then return end

    print("[MEGA FARM] Начало сбора купюры:", item:GetDebugId(4))
    local counter = 0
    local startTime = tick()

    repeat
        if not IsRunning then break end
        
        if hum and hum.Health <= 0 then
            warn("[MEGA FARM] Персонаж погиб во время сбора! Монета добавлена в PERMANENT BLACKLIST:", item:GetDebugId(4))
            PermanentBlacklist[item] = true 
            break
        end

        if tick() - startTime > 3 then
            warn("[MEGA FARM] Превышен таймаут сбора (3 сек). Монета добавлена во временный блеклист на 10 сек:", item:GetDebugId(4))
            Blacklist[item] = true
            task.delay(10, function()
                Blacklist[item] = nil
                print("[MEGA FARM] Временный блеклист снят для монеты:", item:GetDebugId(4))
            end)
            break
        end

        root = getRoot()
        hum = getHumanoid()

        if root and hum then
            local offset = math.sin(counter) * 5
            local rotX = math.cos(counter) * 180
            local rotY = counter * 150
            local rotZ = math.sin(counter) * 180
            
            root.CFrame = item.CFrame * CFrame.new(offset, 0, 0) * CFrame.Angles(math.rad(rotX), math.rad(rotY), math.rad(rotZ))
            counter = counter + 0.3
        end
        task.wait()
    until not item or not item.Parent or not item:IsDescendantOf(workspace) or not IsRunning or Blacklist[item] or PermanentBlacklist[item]
end

-- Основной цикл сбора
task.spawn(function()
    local lastCount = -1
    while IsRunning do
        local root = getRoot()
        local hum = getHumanoid()
        
        if root and hum and hum.Health > 0 then
            local cashItems = getValidCash()

            if #cashItems > 0 then
                -- Логируем только если количество реально изменилось, чтобы не спамить в консоль
                if #cashItems ~= lastCount then
                    print("[MEGA FARM] Найдено реальных купюр на карте:", #cashItems)
                    lastCount = #cashItems
                end
                
                for _, item in pairs(cashItems) do
                    if not IsRunning or Blacklist[item] or PermanentBlacklist[item] then break end
                    collect(item)
                end
            else
                lastCount = 0
            end
        end
        task.wait(0.2) -- Чуть увеличили задержку проверки, чтобы снизить нагрузку
    end
end)

-- Жесткий покадровый телепорт в AFK позицию, если нет активных купюр
local isAlreadyAFK = false
RunService.Heartbeat:Connect(function()
    if not IsRunning then return end
    
    local root = getRoot()
    local hum = getHumanoid()
    
    if root and hum and hum.Health > 0 then
        local cashItems = getValidCash()

        if #cashItems == 0 then
            if not isAlreadyAFK then
                print("[MEGA FARM] На карте нет реальных монет. Удержание AFK позиции.")
                isAlreadyAFK = true
            end
            root.Velocity = Vector3.new(0, 0, 0)
            root.RotVelocity = Vector3.new(0, 0, 0)
            root.CFrame = CFrame.new(AFK_POS)
        else
            isAlreadyAFK = false
        end
    end
end)

ParticlesFolder.ChildAdded:Connect(function(child)
    if IsRunning and child.Name == "Cash" then
        task.wait(0.05)
        if child:IsA("BasePart") and child.Parent then
            print("[MEGA FARM] Обнаружена новая валидная купюра:", child:GetDebugId(4))
            collect(child)
        end
    end
end)
