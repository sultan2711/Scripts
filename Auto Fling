local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local Workspace = game:GetService("Workspace")

local PLAYER = Players.LocalPlayer
local CAMERA = Workspace.CurrentCamera
local IS_FLINGING = false

local ConnectionLoop
local ConnectionAntiFling
local savedCFrame = nil
local tickCounter = 0 

if CoreGui:FindFirstChild("FlingGui") then CoreGui.FlingGui:Destroy() end

local ScreenGui = Instance.new("ScreenGui", CoreGui)
ScreenGui.Name = "FlingGui"

local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 200, 0, 110)
MainFrame.Position = UDim2.new(0.5, -100, 0, 50)
MainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
MainFrame.BorderSizePixel = 0

local TextBox = Instance.new("TextBox", MainFrame)
TextBox.Size = UDim2.new(1, -20, 0, 30)
TextBox.Position = UDim2.new(0, 10, 0, 15)
TextBox.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
TextBox.PlaceholderText = "Player Name..."
TextBox.Text = ""
TextBox.TextColor3 = Color3.new(1, 1, 1)
TextBox.Font = Enum.Font.SourceSans
TextBox.TextSize = 16

local StartBtn = Instance.new("TextButton", MainFrame)
StartBtn.Size = UDim2.new(1, -20, 0, 35)
StartBtn.Position = UDim2.new(0, 10, 0, 55)
StartBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
StartBtn.Text = "START FLING"
StartBtn.TextColor3 = Color3.new(1, 1, 1)
StartBtn.Font = Enum.Font.SourceSansBold
StartBtn.TextSize = 16

local function getTarget()
    local text = TextBox.Text:lower()
    if text == "" then return nil end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= PLAYER and (p.Name:lower():sub(1, #text) == text or p.DisplayName:lower():sub(1, #text) == text) then
            return p
        end
    end
    return nil
end

local function resetCamera()
    local myChar = PLAYER.Character
    local myHum = myChar and myChar:FindFirstChildOfClass("Humanoid")
    if myHum then
        CAMERA.CameraSubject = myHum
    end
end

local function returnToSafety()
    local myChar = PLAYER.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    local myHum = myChar and myChar:FindFirstChildOfClass("Humanoid")
    
    if myHum then
        myHum.PlatformStand = false
        myHum:ChangeState(Enum.HumanoidStateType.GettingUp)
    end
    
    if myRoot and savedCFrame then
        myRoot.CFrame = savedCFrame
        myRoot.Velocity = Vector3.new(0, 0, 0)
        myRoot.RotVelocity = Vector3.new(0, 0, 0)
    end
end

local function toggleAntiFling(state)
    if not state then
        if ConnectionAntiFling then
            ConnectionAntiFling:Disconnect()
            ConnectionAntiFling = nil
        end
        return
    end
    
    ConnectionAntiFling = RunService.Stepped:Connect(function()
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= PLAYER and player.Character then
                local root = player.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    root.CanCollide = false
                end
            end
        end
    end)
end

StartBtn.MouseButton1Click:Connect(function()
    IS_FLINGING = not IS_FLINGING
    
    if IS_FLINGING then
        local targetPlayer = getTarget()
        if not targetPlayer then
            IS_FLINGING = false
            return
        end
        
        local myChar = PLAYER.Character
        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if myRoot then
            savedCFrame = myRoot.CFrame
        end
        
        StartBtn.Text = "STOP"
        StartBtn.BackgroundColor3 = Color3.fromRGB(100, 0, 0)
        tickCounter = 0
        
        toggleAntiFling(true)
        
        local wasWaitingForRespawn = false
        local lastTargetPosition = nil
        local lastTargetVelocity = Vector3.new(0, 0, 0)

        ConnectionLoop = RunService.Heartbeat:Connect(function()
            myChar = PLAYER.Character
            myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
            local myHum = myChar and myChar:FindFirstChildOfClass("Humanoid")
            
            if not myRoot or not myHum or myHum.Health <= 0 then
                IS_FLINGING = false
                StartBtn.Text = "START FLING"
                StartBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
                if ConnectionLoop then ConnectionLoop:Disconnect() end
                toggleAntiFling(false)
                resetCamera()
                savedCFrame = nil
                return
            end

            local tChar = targetPlayer.Character
            local tRoot = tChar and tChar:FindFirstChild("HumanoidRootPart")
            local tHum = tChar and tChar:FindFirstChildOfClass("Humanoid")
            
            if tRoot and tHum and tHum.Health > 0 then
                if wasWaitingForRespawn then
                    savedCFrame = myRoot.CFrame
                    wasWaitingForRespawn = false
                end

                if CAMERA.CameraSubject ~= tHum then
                    CAMERA.CameraSubject = tHum
                end

                if not myHum.PlatformStand then
                    myHum.PlatformStand = true
                    myHum:ChangeState(Enum.HumanoidStateType.Physics)
                end

                local currentTargetPosition = tRoot.Position
                local currentTargetVelocity = tRoot.Velocity
                local predictionOffset = Vector3.new(0, 0, 0)
                
                if lastTargetPosition then
                    local deltaVelocity = currentTargetVelocity - lastTargetVelocity
                    predictionOffset = (currentTargetVelocity * 0.45) + (deltaVelocity * 0.8)
                else
                    predictionOffset = currentTargetVelocity * 0.35
                end
                
                if predictionOffset.Magnitude > 35 then
                    predictionOffset = predictionOffset.Unit * 35
                end
                
                lastTargetPosition = currentTargetPosition
                lastTargetVelocity = currentTargetVelocity

                tickCounter = tickCounter + 1
                
                local forwardVector = tRoot.CFrame.LookVector
                local ramOffset = forwardVector * (math.cos(tickCounter * 1.2) * 5)
                
                local finalPosition = currentTargetPosition + predictionOffset + ramOffset
                
                if tHum.FloorMaterial == Enum.Material.Air then
                    finalPosition = Vector3.new(finalPosition.X, currentTargetPosition.Y + 1.5, finalPosition.Z)
                else
                    finalPosition = Vector3.new(finalPosition.X, currentTargetPosition.Y + 0.5, finalPosition.Z)
                end
                
                myRoot.CFrame = CFrame.new(finalPosition, currentTargetPosition)
                
                local moveDir = currentTargetVelocity.Magnitude > 0.1 and currentTargetVelocity.Unit or forwardVector
                myRoot.Velocity = moveDir * -8500
                myRoot.RotVelocity = Vector3.new(650, 650, 650)
            else
                wasWaitingForRespawn = true
                lastTargetPosition = nil
                lastTargetVelocity = Vector3.new(0, 0, 0)
                resetCamera()
                returnToSafety()
            end
        end)
    else
        StartBtn.Text = "START FLING"
        StartBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
        if ConnectionLoop then ConnectionLoop:Disconnect() end
        toggleAntiFling(false)
        resetCamera()
        returnToSafety()
        savedCFrame = nil
    end
end)
