local function UpdateGUI(targetName)
    if not Running then return end
    
    if not MASTER_SWITCH then
        Title.Text = "SYSTEM OFF"
        Title.TextColor3 = Color3.new(1, 0.3, 0.3)
    else
        Title.Text = targetName and ("LOCKED: " .. targetName:sub(1, 10)) or (ENABLED and "SCANNING..." or "READY")
        Title.TextColor3 = targetName and Color3.new(0.3, 1, 0.3) or Color3.new(1, 1, 1)
    end
    
    Info.Text = string.format(
        "Team Check: %s\nWall Check: %s\nIgnore Friends: %s",
        FREE_FOR_ALL and "OFF" or "ON",
        WALL_CHECK and "ON" or "OFF",
        IGNORE_FRIENDS and "ON" or "OFF"
    )
    
    ButtonFFA.Text = "FFA: " .. (FREE_FOR_ALL and "ON" or "OFF")
    ButtonWall.Text = "WALL: " .. (WALL_CHECK and "ON" or "OFF")
    ButtonFriends.Text = "FRIENDS: " .. (IGNORE_FRIENDS and "ON" or "OFF")
    ButtonMaster.Text = "SYSTEM: " .. (MASTER_SWITCH and "ON" or "OFF")
    ButtonMaster.BackgroundColor3 = MASTER_SWITCH and Color3.fromRGB(0, 80, 0) or Color3.fromRGB(80, 0, 0)
end

