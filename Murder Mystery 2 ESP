-- 1. ЛОГИКА СКАЧИВАНИЯ И ЗАГРУЗКИ ИЗ ЛОКАЛЬНОЙ ПАМЯТИ
local function prepareLocalImage()
    if not writefile or not game.HttpGet then
        warn("[LOCAL STORAGE ERROR] Твой эксплойт не поддерживает writefile или HttpGet! Переключаюсь на стандартный веб-метод.")
        localAssetId = rawUrl
        return
    end

    local success, err = pcall(function()
        print("[LOCAL STORAGE] Проверяю наличие сохраненного файла в локальной памяти...")
        
        print("[LOCAL STORAGE] Загружаю картинку из интернета для сохранения...")
        local imageData = game:HttpGet(rawUrl)
        writefile(localFileName, imageData)
        print("[LOCAL STORAGE] Файл успешно скачан и сохранен локально как: " .. localFileName)
        
        if getcustomasset then
            localAssetId = getcustomasset(localFileName)
            print("[LOCAL STORAGE] Файл успешно инициализирован из памяти: " .. tostring(localAssetId))
        else
            localAssetId = "rbxasset://.." .. localFileName
            print("[LOCAL STORAGE] Преобразовано в rbxasset.")
        end
    end)

    if not success then
        warn("[LOCAL STORAGE ERROR] Не удалось сохранить файл локально: " .. tostring(err) .. ". Переключаюсь на прямую ссылку.")
        localAssetId = rawUrl
    end
end

prepareLocalImage()

