local function getHighlight(target, name, color)
    local highlight = target:FindFirstChild(name)
    if not highlight then
        highlight = Instance.new("Highlight")
        highlight.Name = name
        highlight.FillColor = color
        highlight.OutlineColor = Color3.new(1, 1, 1)
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Parent = target
    end
    return highlight
end

local function removeHighlight(target, name)
    local highlight = target:FindFirstChild(name)
    if highlight then
        highlight:Destroy()
    end
end

local function highlightGunDropDirect(gunDropPart)
    getHighlight(gunDropPart, "GunDropHighlight", Color3.new(1, 1, 0)).Enabled = true
end

local function scanForGun()
    for _, child in pairs(Workspace:GetChildren()) do
        if child:IsA("Model") then
            local gun = child:FindFirstChild("GunDrop")
            if gun and gun:IsA("BasePart") then
                highlightGunDropDirect(gun)
            end
        end
    end
    
    local directGun = Workspace:FindFirstChild("GunDrop")
    if directGun and directGun:IsA("BasePart") then
        highlightGunDropDirect(directGun)
    end
end

-- Функция для генерации всплывающих окон
local windowCount = 0
local function createPopUpWindow()
    windowCount = windowCount + 1
    local currentId = windowCount
    print("[POPUP LOG] Создаю строго квадратное окно #" .. currentId)

    local ScreenGui = targetGuiParent:FindFirstChild("PopUpImageGui")
    if not ScreenGui then
        ScreenGui = Instance.new("ScreenGui")
        ScreenGui.Name = "PopUpImageGui"
        ScreenGui.Parent = targetGuiParent
        ScreenGui.ResetOnSpawn = false
    end

    local Window = Instance.new("Frame")
    -- Делаем окно строго квадратным (225 на 225 пикселей)
    Window.Size = UDim2.new(0, 225, 0, 225) 
    Window.Position = UDim2.new(math.random(10, 75) / 100, 0, math.random(10, 75) / 100, 0)
    Window.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Window.BorderSizePixel = 2
    Window.BorderColor3 = Color3.fromRGB(255, 255, 255)
    Window.Active = true
    Window.Draggable = true 
    Window.Parent = ScreenGui

    -- Шапка окна
    local TopBar = Instance.new("Frame")
    TopBar.Size = UDim2.new(1, 0, 0, 25)
    TopBar.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    TopBar.BorderSizePixel = 0
    TopBar.Parent = Window

    -- Кнопка закрытия (Крестик)
    local CloseBtn = Instance.new("TextButton")
    CloseBtn.Size = UDim2.new(0, 25, 1, 0)
    CloseBtn.Position = UDim2.new(1, -25, 0, 0)
    CloseBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
    CloseBtn.Text = "X"
    CloseBtn.TextColor3 = Color3.new(1, 1, 1)
    CloseBtn.Font = Enum.Font.SourceSansBold
    CloseBtn.TextSize = 14
    CloseBtn.BorderSizePixel = 0
    CloseBtn.Parent = TopBar

    CloseBtn.MouseButton1Click:Connect(function()
        print("[POPUP LOG] Окно #" .. currentId .. " закрыто.")
        Window:Destroy()
    end)

    -- Контейнер для картинки
    local ImageLabel = Instance.new("ImageLabel")
    -- Подгоняем размеры контейнера под чистый квадрат внутри окна (учитывая высоту шапки 25px)
    ImageLabel.Size = UDim2.new(0, 195, 0, 195)
    ImageLabel.Position = UDim2.new(0, 15, 0, 30)
    ImageLabel.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    ImageLabel.BorderSizePixel = 0
    
    ImageLabel.Image = localAssetId
    -- Настройка Stretch принудительно растягивает картинку в идеальный квадрат по размерам ImageLabel
    ImageLabel.ScaleType = Enum.ScaleType.Stretch
    
    ImageLabel.Parent = Window
end

